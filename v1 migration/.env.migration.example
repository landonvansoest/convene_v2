# Copy to .env.migration (same folder). Use service_role keys for both projects.
# Never commit .env.migration.
#
# PostgREST egress: a full run (including DRY_RUN=true) paginates every v1 table
# in migrate.mjs — large download. Prefer pausing the v1 project in the Dashboard
# when you are not actively migrating. npm run migrate:v1-v2 refuses CI unless
# ALLOW_V1_ETL_IN_CI=true.

# Source: legacy v1 Supabase project (read-only ETL)
V1_SUPABASE_URL=https://xxxx.supabase.co
V1_SUPABASE_SERVICE_ROLE_KEY=

# Target: v2 Supabase project (writes data)
V2_SUPABASE_URL=https://yyyy.supabase.co
V2_SUPABASE_SERVICE_ROLE_KEY=

# Set true to log counts and skip v2 writes (still reads all v1 tables)
DRY_RUN=false

# Only if you run this script in GitHub Actions / other CI
# ALLOW_V1_ETL_IN_CI=true

# Optional: comma-separated phases only (default = all)
# Phases: categories, auth_users, users_profile, expert_profiles, expert_availability,
#         conversations, messages, bookings, reviews_experts, reviews_learners,
#         subscriptions, response_times
# MIGRATE_PHASES=categories,auth_users
