# Supabase (v2 project — run supabase/v2/*.sql first)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Legacy anon JWT (eyJ...) or new publishable key (sb_publishable_...). If auth times out,
# re-enable legacy keys in Dashboard → Settings → API and use the anon JWT here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only (Route Handlers, cron, webhooks)
# Legacy service_role JWT (eyJ...) or new secret key (sb_secret_...).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# System inbox: "Team Convene" welcome DM after signup (first GET /api/me). Use UUID and/or email
# (email looks up public.users). Names should be Team / Convene. Run 014_welcome_inbox_sent.sql.
#CONVENE_TEAM_USER_ID=
#CONVENE_TEAM_EMAIL=

# System inbox: "Convene Support" persona for help-ticket conversations. Distinct from the welcome
# sender above. If unset, the support sender falls back to CONVENE_TEAM_USER_ID/EMAIL.
# Recommended: a dedicated public.users row named Convene / Support so the dashboard inbox + admin
# Help Tickets view show a separate avatar / name from the welcome inbox.
#CONVENE_SUPPORT_USER_ID=
#CONVENE_SUPPORT_EMAIL=

# Bible notification endpoints
NOTIFICATION_WEBHOOK_SECRET=generate_a_long_random_string
CRON_SECRET=another_long_random_string

# Public site URL (reminder emails / deep links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Maps Places + Time Zone API (learner registration hometown lookup)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Stripe (Route Handlers under /api/stripe/*)
# Paste the full key with no quotes or trailing spaces. Test/live keys must match NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY.
# If Stripe returns "Invalid API Key", re-copy from Dashboard → Developers → API keys (old keys stop working if rolled).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Dev only — matches legacy Express bypass. Also auto-enabled on Vercel (`VERCEL=1`) until launch bypass is removed.
ALLOW_PAYMENT_BYPASS=false
# Client: show “Skip pay (dev)” on /sessions for unpaid legacy bookings (server must allow bypass; see ALLOW_PAYMENT_BYPASS / admin footer toggle)
#NEXT_PUBLIC_CONVENE_DEV_SESSION_PAYMENT_SKIP=true
# Expert registration: show “skip payout” on the payout step without toggling admin settings
#NEXT_PUBLIC_ALLOW_PAYOUT_FORM_BYPASS=true
# Runtime admin toggle can also enable bypass (non-production only)

# Admin (assert-admin: Bearer OR signed-in user with this email)
ADMIN_DASHBOARD_SECRET=
ADMIN_EMAIL=
# Mailbox that receives operator alerts (new expert registration pending review,
# new help tickets, etc). Falls back to ADMIN_EMAIL, then to team.convene.io@gmail.com.
ADMIN_ALERT_EMAIL=team.convene.io@gmail.com

# Daily.co (video rooms — server route)
DAILY_API_KEY=
# Optional; defaults in code if unset (subdomain for join URLs)
DAILY_DOMAIN=
NEXT_PUBLIC_DAILY_DOMAIN=

# Stripe subscription Checkout (Price id from Dashboard → Products)
STRIPE_SUBSCRIPTION_PRICE_ID=

# Email (SendGrid) — optional; logs in dev if unset
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
# Optional display name + reply-to (improves deliverability)
#SENDGRID_FROM_NAME=Convene
#SENDGRID_REPLY_TO=support@convene.io
# Optional absolute HTTPS logo URL for transactional email header (defaults to NEXT_PUBLIC_APP_URL/email/convene_logo.png)
#CONVENE_EMAIL_LOGO_URL=https://convene-0626.vercel.app/email/convene_logo.png?v=5

# SMS (Twilio) — optional; E.164 numbers only for delivery
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# OpenAI (expert registration generators)
OPENAI_API_KEY=

# Expert availability: package-deal columns (run supabase/v2/018_expert_availability_package_deal.sql first)
#EXPERT_AVAILABILITY_PACKAGE_COLUMNS=true
